    <worksheet name='Crowd Sizes'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontsize='12'>Crowd Sizes Across Different Months</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='hotel_bookings_cleaned (hotel_bookings_cleaned)' name='federated.1hiq0pk1ujqps31ej5v8u1ctm6hu' />
          </datasources>
          <datasource-dependencies datasource='federated.1hiq0pk1ujqps31ej5v8u1ctm6hu'>
            <column caption='Crowd calculation' datatype='integer' name='[Calculation_1418352456180535302]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[adults]+[children]+[babies]' />
            </column>
            <column caption='Adults' datatype='integer' name='[adults]' role='measure' type='quantitative' />
            <column caption='Arrival Date Month' datatype='string' name='[arrival_date_month]' role='dimension' type='nominal'>
